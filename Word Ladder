#include <iostream>
#include <vector>
#include <string>
#include <unordered_set>
#include <queue>

using namespace std;

class Solution {
public:
    int ladderLength(string beginWord, string endWord, vector<string>& wordList) {
        unordered_set<string> dict(wordList.begin(), wordList.end());
        
        // If the endWord isn't in the list, no path exists
        if (dict.find(endWord) == dict.end()) return 0;
        
        queue<string> q;
        q.push(beginWord);
        
        int ladder = 1; // Start with length 1 (the beginWord)
        
        while (!q.empty()) {
            int n = q.size();
            
            // Process all words at the current "distance" level
            for (int i = 0; i < n; i++) {
                string word = q.front();
                q.pop();
                
                if (word == endWord) return ladder;
                
                // Try changing every character of the current word
                for (int j = 0; j < word.length(); j++) {
                    char originalChar = word[j];
                    
                    for (char c = 'a'; c <= 'z'; c++) {
                        word[j] = c;
                        
                        if (dict.count(word)) {
                            q.push(word);
                            dict.erase(word); // Mark as visited by removing from set
                        }
                    }
                    word[j] = originalChar; // Backtrack to original state
                }
            }
            ladder++; // Move to the next transformation level
        }
        
        return 0; // No path found
    }
};
